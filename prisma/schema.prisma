generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id           Int        @id @default(autoincrement())
  nome         String
  email        String     @unique
  telefone     String?
  dataCadastro DateTime   @default(now())
  enderecos    Endereco[]
  pedidos      Pedido[]
}


model Endereco {
  id          Int     @id @default(autoincrement())
  clienteId   Int
  cep         String
  rua         String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
  cliente     Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Pedido {
  id              Int      @id @default(autoincrement())
  clienteId       Int
  tipoLivro       String
  valorTotal      Float
  statusPagamento String   @default("pendente")
  statusEnvio     String   @default("nao_aplicavel")
  dataPedido      DateTime @default(now())
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
}

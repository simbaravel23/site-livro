datasource db {
  provider = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
}

model Cliente {
  id           Int        @id @default(autoincrement())
  nome         String
  email        String     @unique
  telefone     String?
  dataCadastro DateTime   @default(now())
  enderecos    Endereco[]
  pedidos      Pedido[]
}

model Endereco {
  id          Int     @id @default(autoincrement())
  clienteId   Int
  cliente     Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  cep         String
  rua         String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  estado      String
}

model Pedido {
  id              Int      @id @default(autoincrement())
  clienteId       Int
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  tipoLivro       String   // "fisico" ou "ebook"
  valorTotal      Float
  statusPagamento String   @default("pendente") // "pendente", "aprovado", "recusado"
  statusEnvio     String   @default("nao_aplicavel") // "enviado", "entregue", "nao_aplicavel"
  dataPedido      DateTime @default(now())
}